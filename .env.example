# 复制为仓库根目录 .env 后再执行 Docker Compose。
# .env 已被 Git 忽略；以下值只是占位符，不要直接用于公网或生产环境。

# MySQL
MYSQL_ROOT_PASSWORD=replace-with-a-local-root-password
DB_USERNAME=ekb
DB_PASSWORD=replace-with-a-local-database-password
MYSQL_PORT=3306

# Redis
REDIS_PASSWORD=replace-with-a-local-redis-password
REDIS_PORT=6379

# RabbitMQ（management 端口用于 P0-3 可靠性演练）
RABBITMQ_USERNAME=ekb
RABBITMQ_PASSWORD=replace-with-a-local-rabbitmq-password
RABBITMQ_VIRTUAL_HOST=/
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# MinIO
MINIO_ACCESS_KEY=replace-with-a-local-minio-user
MINIO_SECRET_KEY=replace-with-a-local-minio-password
MINIO_BUCKET=ekb-documents
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Qdrant
QDRANT_COLLECTION=rag_chunks_v1
QDRANT_PORT=6333

# Java API
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-bytes
BACKEND_PORT=8080
AI_SERVICE_CONNECT_TIMEOUT_MS=2000
AI_SERVICE_RESPONSE_TIMEOUT_SECONDS=180
# -1 表示禁用；启用前应使用当前 fixed dataset 重跑并确认误拒率。
RAG_MINIMUM_RELEVANCE_SCORE=-1

# 本地 embedding。模型由 Compose 的一次性 model-init 服务下载到命名卷。
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
HF_ENDPOINT=https://huggingface.co
AI_SERVICE_PORT=8000

# 可选：不配置时索引和向量检索仍可使用；有上下文的 RAG 生成会返回 503。
LLM_PROVIDER=none
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
DEEPSEEK_API_KEY=
