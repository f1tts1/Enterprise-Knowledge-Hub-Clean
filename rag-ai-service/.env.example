APP_NAME=rag-ai-service
APP_ENV=local
HOST=0.0.0.0
PORT=8000

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=replace-with-your-local-minio-access-key
MINIO_SECRET_KEY=replace-with-your-local-minio-secret-key
MINIO_SECURE=false
MINIO_BUCKET=ekb-documents

CHUNK_SIZE=800
CHUNK_OVERLAP=120

# V1 默认使用本地 embedding 模型。
# 该路径是从 rag-ai-service 目录启动 uvicorn 时的相对路径；
# 也可以改成本机 embedding 模型目录的绝对路径；不要把个人路径写入提交。
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_PATH=../.models/bge-small-zh-v1.5
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true
EMBEDDING_BATCH_SIZE=32

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_chunks_v1

# 可选：仅在需要 RAG 生成时配置 OpenAI-compatible 服务。
LLM_PROVIDER=none
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
DEEPSEEK_API_KEY=
